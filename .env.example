# yescode-proxy environment template — copy to .env, fill in, do NOT commit
PORT=18790
BIND=127.0.0.1

# Upstream hosts (co-cdn is the China-friendly fallback)
YESCODE_PRIMARY=co.yes.vg
YESCODE_FALLBACK=co-cdn.yes.vg

# Path prefix prepended to every upstream call.
#   personal account → leave blank
#   team account     → /team
YESCODE_PATH_PREFIX=/team

# Single unified key used for all routes (claude/openai/gemini).
# The proxy force-overrides whatever the client sends, so clients can use any
# placeholder (e.g. sk-12345678) in their config and the real key never leaves
# this file.
YESCODE_API_KEY=

# Optional per-route overrides. Leave blank to use YESCODE_API_KEY everywhere.
# Useful only if your account issues distinct keys per protocol.
YESCODE_API_KEY_ANTHROPIC=
YESCODE_API_KEY_OPENAI=
YESCODE_API_KEY_GEMINI=

YESCODE_TIMEOUT_MS=3600000
