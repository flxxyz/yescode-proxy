# yescode-proxy environment template — copy to .env, fill in, do NOT commit
PORT=18790
BIND=127.0.0.1

# Upstream URLs — full scheme + host + optional path prefix. Each upstream is
# parsed independently: the protocol picks http/https, host[:port] addresses the
# socket, and the path becomes a prefix prepended to every route. co-cdn is the
# China-friendly fallback. Team account → keep the /team suffix; personal
# account → drop it (e.g. https://co.yes.vg).
YESCODE_PRIMARY_URL=https://co.yes.vg/team
YESCODE_FALLBACK_URL=https://co-cdn.yes.vg/team

# Single unified key used for all routes (claude/openai/gemini). This is the
# primary credential. The proxy force-overrides whatever the client sends, so
# clients can use any placeholder (e.g. sk-12345678) in their config and the
# real key never leaves this file.
YESCODE_API_KEY=

# Note: /v1/chat/completions is a universal endpoint — the model-name prefix
# (claude* -> Anthropic, gemini* -> Gemini, else -> OpenAI) picks the upstream
# and the request + response are protocol-translated in both directions. The
# per-route fallback keys and the upstream fingerprints (Claude-CLI metadata,
# codex User-Agent) are selected by that RESOLVED backend, not by the URL.

# Per-route FALLBACK keys. When the upstream rejects YESCODE_API_KEY with a
# key-failure status (see YESCODE_KEY_FALLBACK_STATUSES), the proxy retries the
# same request with the matching fallback key below. Leave blank to disable
# fallback for that route. Fallback keys reuse the same upstream URLs (same
# /team prefix), so they must be valid under that prefix.
YESCODE_API_KEY_ANTHROPIC=
YESCODE_API_KEY_OPENAI=
YESCODE_API_KEY_GEMINI=

# Upstream statuses that trigger the fallback-key retry. Comma-separated.
# Default 401,403 (auth revoked / model-or-provider not allowed). 5xx is NOT
# included — those are upstream-side faults a different key won't fix.
YESCODE_KEY_FALLBACK_STATUSES=401,403

# Upstream statuses treated as transient: the proxy retries the SAME request
# (same key) on the primary's backoff schedule (200ms, 600ms), then the fallback
# host once, before surfacing the error. Mirrors the auto-retry the Anthropic/
# OpenAI SDKs do client-side, so plain clients survive a brief "no capacity
# available" (503) blip instead of seeing a hard failure. Comma-separated.
# Default 429,503,529 (rate-limited / no capacity / overloaded). Distinct from
# YESCODE_KEY_FALLBACK_STATUSES: those switch key, these just retry.
YESCODE_RETRY_STATUSES=429,503,529

YESCODE_TIMEOUT_MS=30000

# --- OpenAI / codex route fingerprint ---
# YesCode gates codex models (gpt-5.x / *-codex on /v1/responses) behind a
# User-Agent prefix check: a UA that looks like a codex client routes to the
# real Codex app-server; anything else falls through to an unconfigured path
# that 503s with "Codex app-server responses fallback is not configured". The
# proxy spoofs a codex UA on the OpenAI route so gpt-5.x works. The defaults
# below already pass the gate — only override to track a specific codex build.
YESCODE_CODEX_CLI_VERSION=0.137.0
# Full UA string. Defaults to codex_cli_rs/<YESCODE_CODEX_CLI_VERSION>. Must
# start with "codex" or the gate rejects it.
YESCODE_CODEX_USER_AGENT=
# `originator` header. Sent for fidelity; not load-bearing (UA alone gates).
YESCODE_CODEX_ORIGINATOR=codex_cli_rs

# --- Gemini route fingerprint ---
# YesCode's gemini upstream 403s on user-agents that look like a competing SDK
# (e.g. the OpenAI JS SDK's "OpenAI/JS ..."). The gemini route overrides the UA
# with an official-looking Google GenAI SDK string. It's a blacklist (curl and
# absent UAs pass), so any non-OpenAI value works — only override to track a
# specific Gemini client build.
YESCODE_GEMINI_USER_AGENT=google-genai-sdk/1.16.0 gl-node/v22.0.0
